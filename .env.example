# Copy to .env and fill in. The Arango values come from your deployment's credentials.
ARANGO_HOST=https://your-deployment.arango.ai
ARANGO_DB=incident_demo
ARANGO_USER=root
ARANGO_PASSWORD=your-password
OPENAI_API_KEY=sk-...

# GraphRAG knowledge graph (the runbook KG lives in its own project/db; services are deployed once via the UI)
GRAPHRAG_DB=_system
GRAPHRAG_PROJECT=test-incident-demo
