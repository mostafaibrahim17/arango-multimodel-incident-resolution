# Copy to .env and fill in. The Arango values come from your deployment's credentials.
ARANGO_HOST=https://your-deployment.arango.ai
ARANGO_DB=incident_demo
ARANGO_USER=root
ARANGO_PASSWORD=your-password
OPENAI_API_KEY=sk-...

# GraphRAG knowledge graph. The runbook KG is built by AutoGraph; its collections live in the
# same database as the multimodel core (incident_demo) under the AutoGraph project name. Create
# the AutoGraph project once via the UI (it deploys the autograph + retriever services); the
# import -> corpus build -> strategizer -> orchestrate steps then run via the REST API (graphrag_ingest.py).
GRAPHRAG_DB=incident_demo
GRAPHRAG_PROJECT=incident-runbook-autograph
